# Servidor FastAPI
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Configuração Firebase
# Caminho para o arquivo de credenciais do Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=secret/firebase-service-account.json

# API OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Segurança
JWT_SECRET_KEY=your_super_secret_jwt_key_for_session_tokens
ACCESS_TOKEN_EXPIRE_MINUTES=1440
